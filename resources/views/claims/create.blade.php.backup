@push('scripts')
    <script>
        let selectedBeneficiary = null;

        // Toggle between existing and new beneficiary
        document.getElementById('newBeneficiarySwitch').addEventListener('change', function() {
            const existingSection = document.getElementById('existingBeneficiarySection');
            const newSection = document.getElementById('newBeneficiarySection');
            const selectedDisplay = document.getElementById('selectedBeneficiaryDisplay');

            if (this.checked) {
                existingSection.style.display = 'none';
                newSection.style.display = 'block';
                selectedDisplay.style.display = 'none';
                selectedBeneficiary = null;
            } else {
                existingSection.style.display = 'block';
                newSection.style.display = 'none';
            }
        });

        // Search beneficiary
        function searchBeneficiary() {
            const searchTerm = document.getElementById('beneficiarySearch').value;
            const facilityId = document.getElementById('facilityFilter').value;
            const resultsDiv = document.getElementById('beneficiarySearchResults');
            const resultsBody = document.getElementById('beneficiaryResultsBody');

            if (!searchTerm) {
                resultsDiv.style.display = 'none';
                return;
            }

            // Show loading
            resultsBody.innerHTML =
                '<tr><td colspan="5" class="text-center"><div class="spinner-border spinner-border-sm me-2"></div>Searching...</td></tr>';
            resultsDiv.style.display = 'block';

            // Simulate API call (replace with actual endpoint)
            fetch(`/api/beneficiaries/search?q=${searchTerm}&facility=${facilityId}`)
                .then(response => response.json())
                .then(data => {
                    if (data.length === 0) {
                        resultsBody.innerHTML =
                            '<tr><td colspan="5" class="text-center text-muted">No beneficiaries found</td></tr>';
                    } else {
                        resultsBody.innerHTML = data.map(beneficiary => `
                    <tr>
                        <td>${beneficiary.boschma_id}</td>
                        <td>${beneficiary.name}</td>
                        <td>${beneficiary.nin}</td>
                        <td>${beneficiary.facility}</td>
                        <td>
                            <button type="button" class="btn btn-sm btn-primary" 
                                    onclick="selectBeneficiary('${beneficiary.id}', '${beneficiary.name}', '${beneficiary.boschma_id}')">
                                Select
                            </button>
                        </td>
                    </tr>
                `).join('');
                    }
                })
                .catch(error => {
                    resultsBody.innerHTML =
                        '<tr><td colspan="5" class="text-center text-danger">Error searching beneficiaries</td></tr>';
                });
        }

        // Select beneficiary
        function selectBeneficiary(id, name, boschmaId) {
            selectedBeneficiary = {
                id,
                name,
                boschma_id: boschmaId
            };

            document.getElementById('selectedBeneficiaryName').textContent = name;
            document.getElementById('selectedBeneficiaryId').textContent = boschmaId;
            document.getElementById('selectedBeneficiaryDisplay').style.display = 'block';
            document.getElementById('beneficiarySearchResults').style.display = 'none';
            document.getElementById('beneficiarySearch').value = '';
        }

        // Clear beneficiary selection
        function clearBeneficiarySelection() {
            selectedBeneficiary = null;
            document.getElementById('selectedBeneficiaryDisplay').style.display = 'none';
        }

        // Update claim fields based on claim type
        function updateClaimFields() {
            const claimType = document.querySelector('select[name="claim_type"]').value;
            // Add specific field requirements based on claim type
            // This can be expanded to show/hide specific fields
        }

        // Validate claim submission
        function validateClaimSubmission() {
            const checkboxes = [
                'validateBeneficiary',
                'validateEligibility',
                'validateClaimDetails',
                'validateDocuments'
            ];

            const uncheckedBoxes = checkboxes.filter(id => !document.getElementById(id).checked);

            if (uncheckedBoxes.length > 0) {
                alert('Please complete all validation checkboxes before submitting the claim.');
                return false;
            }

            if (!selectedBeneficiary && !document.getElementById('newBeneficiarySwitch').checked) {
                alert('Please select a beneficiary or choose to create a new one.');
                return false;
            }

            return true;
        }

        // Save as draft
        function saveAsDraft() {
            const form = document.getElementById('claimCreationForm');
            const formData = new FormData(form);
            formData.append('save_as_draft', 'true');

            fetch('{{ route('claims.store') }}', {
                    method: 'POST',
                    body: formData,
                    headers: {
                        'X-CSRF-TOKEN': '{{ csrf_token() }}'
                    }
                })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        alert('Claim saved as draft successfully!');
                        window.location.href = '{{ route('claims.index') }}';
                    } else {
                        alert('Error saving draft: ' + data.message);
                    }
                })
                .catch(error => {
                    alert('Error saving draft. Please try again.');
                });
        }

        // Filter beneficiaries by facility
        function filterBeneficiaries() {
            searchBeneficiary();
        }
    </script>
@endpush
