@push('scripts')
    <script>
        function downloadClaim() {
            window.open('{{ route('claims.download', $claim->id) }}', '_blank');
        }

        function approveClaim() {
            if (confirm('Are you sure you want to approve this claim?')) {
                const form = document.createElement('form');
                form.method = 'POST';
                form.action = '{{ route('claims.approve', $claim->id) }}';

                const csrf = document.createElement('input');
                csrf.type = 'hidden';
                csrf.name = '_token';
                csrf.value = '{{ csrf_token() }}';
                form.appendChild(csrf);

                document.body.appendChild(form);
                form.submit();
            }
        }

        function rejectClaim() {
            const reason = prompt('Please enter the rejection reason:');
            if (reason) {
                const form = document.createElement('form');
                form.method = 'POST';
                form.action = '{{ route('claims.reject', $claim->id) }}';

                const csrf = document.createElement('input');
                csrf.type = 'hidden';
                csrf.name = '_token';
                csrf.value = '{{ csrf_token() }}';
                form.appendChild(csrf);

                const rejectionReason = document.createElement('input');
                rejectionReason.type = 'hidden';
                rejectionReason.name = 'rejection_reason';
                rejectionReason.value = reason;
                form.appendChild(rejectionReason);

                document.body.appendChild(form);
                form.submit();
            }
        }

        function addNote() {
            const modal = new bootstrap.Modal(document.getElementById('addNoteModal'));
            modal.show();
        }

        function saveNote() {
            const form = document.getElementById('addNoteForm');
            const formData = new FormData(form);

            fetch('{{ route('claims.add-note', $claim->id) }}', {
                    method: 'POST',
                    body: formData,
                    headers: {
                        'X-CSRF-TOKEN': '{{ csrf_token() }}'
                    }
                })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        alert('Note added successfully!');
                        bootstrap.Modal.getInstance(document.getElementById('addNoteModal')).hide();
                        location.reload();
                    } else {
                        alert('Error adding note: ' + data.message);
                    }
                })
                .catch(error => {
                    alert('Error adding note. Please try again.');
                });
        }

        function viewHistory() {
            window.open('{{ route('claims.audit.trail', $claim->id) }}', '_blank');
        }

        function deleteClaim() {
            if (confirm('Are you sure you want to delete this claim? This action cannot be undone.')) {
                const form = document.createElement('form');
                form.method = 'POST';
                form.action = '{{ route('claims.destroy', $claim->id) }}';

                const csrf = document.createElement('input');
                csrf.type = 'hidden';
                csrf.name = '_token';
                csrf.value = '{{ csrf_token() }}';
                form.appendChild(csrf);

                const method = document.createElement('input');
                method.type = 'hidden';
                method.name = '_method';
                method.value = 'DELETE';
                form.appendChild(method);

                document.body.appendChild(form);
                form.submit();
            }
        }
    </script>
@endpush
