    <script>
        function roApprove() {
            const notes = document.getElementById('roNotes').value;

            if (!confirm('Are you sure you want to approve this claim at the Regional Officer level?')) {
                return;
            }

            fetch(`/claims/{{ $claim->id }}/ro-approve`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'X-CSRF-TOKEN': '{{ csrf_token() }}'
                    },
                    body: JSON.stringify({
                        notes: notes
                    })
                })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        location.reload();
                    } else {
                        alert(data.message || 'Error approving claim');
                    }
                })
                .catch(error => {
                    console.error('Error:', error);
                    alert('Error approving claim');
                });
        }

        function roReject() {
            const notes = document.getElementById('roNotes').value;

            if (!notes.trim()) {
                alert('Please provide rejection notes before rejecting this claim.');
                return;
            }

            if (!confirm('Are you sure you want to reject this claim at the Regional Officer level?')) {
                return;
            }

            fetch(`/claims/{{ $claim->id }}/ro-reject`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'X-CSRF-TOKEN': '{{ csrf_token() }}'
                    },
                    body: JSON.stringify({
                        notes: notes
                    })
                })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        location.reload();
                    } else {
                        alert(data.message || 'Error rejecting claim');
                    }
                })
                .catch(error => {
                    console.error('Error:', error);
                    alert('Error rejecting claim');
                });
        }

        function e5Approve() {
            const notes = document.getElementById('e5Notes').value;

            if (!confirm('Are you sure you want to give final E5 approval for this claim?')) {
                return;
            }

            fetch(`/claims/{{ $claim->id }}/e5-approve`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'X-CSRF-TOKEN': '{{ csrf_token() }}'
                    },
                    body: JSON.stringify({
                        notes: notes
                    })
                })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        location.reload();
                    } else {
                        alert(data.message || 'Error approving claim');
                    }
                })
                .catch(error => {
                    console.error('Error:', error);
                    alert('Error approving claim');
                });
        }

        function e5Reject() {
            const notes = document.getElementById('e5Notes').value;

            if (!notes.trim()) {
                alert('Please provide rejection notes before rejecting this claim.');
                return;
            }

            if (!confirm('Are you sure you want to reject this claim at the E5 level?')) {
                return;
            }

            fetch(`/claims/{{ $claim->id }}/e5-reject`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'X-CSRF-TOKEN': '{{ csrf_token() }}'
                    },
                    body: JSON.stringify({
                        notes: notes
                    })
                })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        location.reload();
                    } else {
                        alert(data.message || 'Error rejecting claim');
                    }
                })
                .catch(error => {
                    console.error('Error:', error);
                    alert('Error rejecting claim');
                });
        }

        function markAsPaid() {
            const reference = document.getElementById('paymentReference').value;
            const date = document.getElementById('paymentDate').value;

            if (!reference.trim()) {
                alert('Please provide a payment reference.');
                return;
            }

            if (!date) {
                alert('Please provide a payment date.');
                return;
            }

            if (!confirm('Are you sure you want to mark this claim as paid?')) {
                return;
            }

            fetch(`/claims/{{ $claim->id }}/mark-as-paid`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'X-CSRF-TOKEN': '{{ csrf_token() }}'
                    },
                    body: JSON.stringify({
                        payment_reference: reference,
                        payment_date: date
                    })
                })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        location.reload();
                    } else {
                        alert(data.message || 'Error marking claim as paid');
                    }
                })
                .catch(error => {
                    console.error('Error:', error);
                    alert('Error marking claim as paid');
                });
        }

        function approveClaim() {
            if (!confirm('Are you sure you want to approve this claim?')) {
                return;
            }

            fetch(`/claims/{{ $claim->id }}/approve`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'X-CSRF-TOKEN': '{{ csrf_token() }}'
                    }
                })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        location.reload();
                    } else {
                        alert(data.message || 'Error approving claim');
                    }
                })
                .catch(error => {
                    console.error('Error:', error);
                    alert('Error approving claim');
                });
        }

        function rejectClaim() {
            const reason = prompt('Please provide the rejection reason:');

            if (!reason || !reason.trim()) {
                alert('Rejection reason is required.');
                return;
            }

            fetch(`/claims/{{ $claim->id }}/reject`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'X-CSRF-TOKEN': '{{ csrf_token() }}'
                    },
                    body: JSON.stringify({
                        rejection_reason: reason
                    })
                })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        location.reload();
                    } else {
                        alert(data.message || 'Error rejecting claim');
                    }
                })
                .catch(error => {
                    console.error('Error:', error);
                    alert('Error rejecting claim');
                });
        }

        function addNote() {
            const content = prompt('Please enter your note:');

            if (!content || !content.trim()) {
                return;
            }

            fetch(`/claims/{{ $claim->id }}/add-note`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'X-CSRF-TOKEN': '{{ csrf_token() }}'
                    },
                    body: JSON.stringify({
                        content: content,
                        is_internal: false
                    })
                })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        location.reload();
                    } else {
                        alert(data.message || 'Error adding note');
                    }
                })
                .catch(error => {
                    console.error('Error:', error);
                    alert('Error adding note');
                });
        }

        function viewHistory() {
            // This would typically open a modal with history details
            alert('History view would be implemented here');
        }

        function deleteClaim() {
            if (!confirm('Are you sure you want to delete this claim? This action cannot be undone.')) {
                return;
            }

            fetch(`/claims/{{ $claim->id }}`, {
                    method: 'DELETE',
                    headers: {
                        'Content-Type': 'application/json',
                        'X-CSRF-TOKEN': '{{ csrf_token() }}'
                    }
                })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        window.location.href = '{{ route('claims.index') }}';
                    } else {
                        alert(data.message || 'Error deleting claim');
                    }
                })
                .catch(error => {
                    console.error('Error:', error);
                    alert('Error deleting claim');
                });
        }

        function downloadClaim() {
            window.open(`/claims/{{ $claim->id }}/export`, '_blank');
        }
    </script>
@endsection
