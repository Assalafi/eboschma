    <style>
        .timeline {
            position: relative;
            padding-left: 30px;
        }

        .timeline-item {
            position: relative;
            padding-bottom: 30px;
        }

        .timeline-item:last-child {
            padding-bottom: 0;
        }

        .timeline-point {
            position: absolute;
            left: -30px;
            top: 5px;
            width: 12px;
            height: 12px;
            border-radius: 50%;
            border: 2px solid #fff;
        }

        .timeline-point-success {
            background-color: #2fb344;
        }

        .timeline-point-primary {
            background-color: #206bc4;
        }

        .timeline-point-warning {
            background-color: #f59e0b;
        }

        .timeline-point-info {
            background-color: #0ea5e9;
        }

        .timeline-point-danger {
            background-color: #dc3545;
        }

        .timeline-content {
            background: #f8f9fa;
            padding: 15px;
            border-radius: 8px;
            border-left: 4px solid #206bc4;
        }

        .timeline-time {
            font-size: 0.875rem;
